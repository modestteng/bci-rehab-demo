{
  "name": "bci-rehab-closed-loop-demo",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:lan": "vite --host 0.0.0.0",
    "build": "tsc -b && vite build",
    "build:single": "tsc -b && vite build --config vite.single.config.ts && node scripts/inline-single.mjs",
    "build:apk": "node scripts/build-apk.mjs",
    "build:artifact": "npm run build:single && node scripts/build-artifact.mjs dist-single/index.html dist-single/artifact.html",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "preview:lan": "vite preview --host 0.0.0.0 --port 4173"
  },
  "dependencies": {
    "@capacitor/android": "^8.4.1",
    "@capacitor/core": "^8.4.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.185.1"
  },
  "devDependencies": {
    "@capacitor/cli": "^8.4.1",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "@types/three": "^0.185.1",
    "@vitejs/plugin-react": "^4.3.1",
    "typescript": "^5.6.0",
    "vite": "^5.4.2"
  }
}
